# ─────────────────────────────────────────────────────────────────────────────
# ASHA Worker Copilot — Backend Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=replace-with-a-strong-random-secret

# ── AWS Credentials (use IAM Role on EC2 instead if possible) ─────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Amazon Bedrock ────────────────────────────────────────────────────────────
# Model must be enabled in Bedrock → Model Access in your AWS console
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Bedrock Knowledge Base (OPTIONAL for prototype — uses local JSON files if not set)
# For production with vector search, create in AWS Console and paste ID here
# Saves ~$50-70/month by not using OpenSearch Serverless
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_DATA_SOURCE_ID=

# ── Amazon Cognito ────────────────────────────────────────────────────────────
# Auto-generated by scripts/setup_aws_resources.py
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# ── DynamoDB Tables ───────────────────────────────────────────────────────────
DYNAMO_PATIENTS_TABLE=asha-patients
DYNAMO_ASSESSMENTS_TABLE=asha-assessments
DYNAMO_VACCINATIONS_TABLE=asha-vaccinations
DYNAMO_SESSIONS_TABLE=asha-sessions

# ── S3 Buckets ────────────────────────────────────────────────────────────────
S3_GUIDELINES_BUCKET=asha-copilot-guidelines
S3_AUDIO_BUCKET=asha-copilot-audio
